# Copy to .env and fill in values before running docker compose up

# Postgres credentials (used by both db and backend containers)
POSTGRES_USER=werewolf
POSTGRES_PASSWORD=change_me_strong_password

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Host port nginx listens on (default 80, use 443 behind a TLS terminator)
PORT=80
